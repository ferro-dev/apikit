# EditorConfig is awesome: http://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
indent_style = space
indent_size = 2
insert_final_newline = true
charset = utf-8
end_of_line = lf

# Trailing whitespace is important in md files
[*.md]
max_line_length = off
trim_trailing_whitespace = false
